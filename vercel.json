{
  "buildCommand": "cd app && npm install && npm run build:h5",
  "outputDirectory": "app/dist/build/h5",
  "framework": null,
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share?id=:id" },
    { "source": "/share-post/:id", "destination": "/api/share-post?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
