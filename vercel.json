{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd app && npm install && npm run build:h5",
  "outputDirectory": "app/dist/build/h5",
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "github": {
    "autoJobCancelation": false,
    "silent": false
  },
  "rewrites": [
    { "source": "/share/:id", "destination": "/api/share?id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
