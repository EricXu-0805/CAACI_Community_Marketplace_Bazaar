VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — optional. H5 only. mp-weixin builds skip Sentry init entirely.
# Empty = disabled (boot still works; errors fall back to console.error).
# Get a DSN from https://sentry.io → New Project → Vue 3.
VITE_SENTRY_DSN=
# Optional release tag for Sentry versions. Defaults to undefined; if set,
# Sentry surfaces "first seen in <release>" on every issue.
VITE_RELEASE=
