VITE_SUPABASE_URL=https://your-project.supabase.co
# Preferred for new projects. During a rolling migration you may instead keep
# VITE_SUPABASE_ANON_KEY set to the legacy JWT-shaped anon key.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Required for every non-H5 build. It must be the exact HTTPS origin serving
# this environment's /api and /share routes (no path/query/credentials).
# H5 ignores it for normal requests and stays on window.location.origin.
# Missing/malformed values stop mp builds before an artifact is emitted; they
# never fall back to production. H5 remains same-origin and does not require it.
VITE_BASE_URL=https://your-app.example.com

# Hosted deployment identity assertions. Vercel Production/Preview builds and
# all Supabase-backed Functions fail closed unless the tier and Supabase ref
# exactly match. Production also requires its reviewed canonical app origin.
# Preview normally derives its unique current origin from VERCEL_URL; if an
# explicit Preview origin is supplied, it must match VERCEL_URL exactly. These
# values are non-secret but MUST be scoped per environment. Local H5 builds do
# not need DEPLOYMENT_EXPECTED_VERCEL_ENV; `vercel dev` rehearsals do.
DEPLOYMENT_EXPECTED_VERCEL_ENV=
SUPABASE_EXPECTED_PROJECT_REF=your20charprojectref
# Required in Production; optional for Vercel Preview.
DEPLOYMENT_APP_ORIGIN=https://your-app.example.com

# Sentry — optional. H5 only. mp-weixin builds skip Sentry init entirely.
# Empty = disabled (boot still works; errors fall back to console.error).
# Get a DSN from https://sentry.io → New Project → Vue 3.
VITE_SENTRY_DSN=

# Optional override for the Sentry release tag. Defaults to:
#   1. process.env.VITE_RELEASE  (this var, if set)
#   2. process.env.VERCEL_GIT_COMMIT_SHA (first 7 chars — auto on Vercel)
#   3. 'dev'  (local development)
# Set this only when you need a custom name (e.g. "v1.2.0-rc1") to override
# the auto-derived git SHA.
VITE_RELEASE=

# ─────────────────────────────────────────────────────────────────────
# Sentry source-map upload — deployment-only by default.
#
# Set all three on Vercel. A remote Vercel deploy also supplies
# VERCEL_GIT_COMMIT_SHA, and the build will:
#   1. Generate sourcemaps with Vite (build.sourcemap = 'hidden')
#   2. Upload them to Sentry under the release tag derived above
#   3. Delete the .map files from dist/ so Vercel never serves them
#
# Without these, the build skips both sourcemap generation AND upload —
# fast local builds, and Sentry shows minified stack traces (which is
# the current state). When all three are set, Sentry stack traces
# resolve back to src/pages/login/index.vue:42 etc.
#
# To create the auth token:
#   Sentry → User Settings → Auth Tokens → Create New Token
#   Scopes needed: project:releases, project:write
#
# A local `vercel build` deliberately does not upload merely because it pulled
# preview credentials. For an intentional manual upload only, set an explicit
# VITE_RELEASE plus SENTRY_UPLOAD_SOURCEMAPS=true for that one command.
#
# DO NOT commit these. Credentials stay in Vercel env vars only.
# ─────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_UPLOAD_SOURCEMAPS=
