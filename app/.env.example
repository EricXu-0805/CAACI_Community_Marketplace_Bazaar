VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — optional. H5 only. mp-weixin builds skip Sentry init entirely.
# Empty = disabled (boot still works; errors fall back to console.error).
# Get a DSN from https://sentry.io → New Project → Vue 3.
VITE_SENTRY_DSN=
# Optional override for the Sentry release tag. Defaults to:
#   1. process.env.VITE_RELEASE  (this var, if set)
#   2. process.env.VERCEL_GIT_COMMIT_SHA (first 7 chars — auto on Vercel)
#   3. 'dev'  (local development)
# Set this only when you need a custom name (e.g. "v1.2.0-rc1") to override
# the auto-derived git SHA.
VITE_RELEASE=
