VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Origin used by mp-weixin code paths as a fallback when window.location isn't
# available (share links, password-reset redirects, direct API endpoint calls
# inside mp builds — see app/src/config/runtime.ts for the full list of call
# sites and the H5 vs mp-weixin routing rules). H5 code uses window.location
# .origin and never reads this — leave blank to use the prod fallback baked
# into runtime.ts. Set this only when you need to override (e.g. point a
# mp-weixin dev build at a Vercel preview deploy or a staging origin).
VITE_BASE_URL=

# Sentry — optional. H5 only. mp-weixin builds skip Sentry init entirely.
# Empty = disabled (boot still works; errors fall back to console.error).
# Get a DSN from https://sentry.io → New Project → Vue 3.
VITE_SENTRY_DSN=

# Optional override for the Sentry release tag. Defaults to:
#   1. process.env.VITE_RELEASE  (this var, if set)
#   2. process.env.VERCEL_GIT_COMMIT_SHA (first 7 chars — auto on Vercel)
#   3. 'dev'  (local development)
# Set this only when you need a custom name (e.g. "v1.2.0-rc1") to override
# the auto-derived git SHA.
VITE_RELEASE=

# ─────────────────────────────────────────────────────────────────────
# Sentry source-map upload — Vercel-only, do NOT set locally.
#
# Set all three on Vercel and the build will:
#   1. Generate sourcemaps with Vite (build.sourcemap = 'hidden')
#   2. Upload them to Sentry under the release tag derived above
#   3. Delete the .map files from dist/ so Vercel never serves them
#
# Without these, the build skips both sourcemap generation AND upload —
# fast local builds, and Sentry shows minified stack traces (which is
# the current state). When all three are set, Sentry stack traces
# resolve back to src/pages/login/index.vue:42 etc.
#
# To create the auth token:
#   Sentry → User Settings → Auth Tokens → Create New Token
#   Scopes needed: project:releases, project:write
#
# DO NOT commit these. Vercel env-vars only (Production + Preview).
# ─────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
