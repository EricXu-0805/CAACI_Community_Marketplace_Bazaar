#!/usr/bin/env bash
# Pre-push hook — mirrors the deterministic local GitHub Actions gates before
# the push leaves your machine. Network-dependent npm audit and opt-in browser
# smoke remain CI/release checks; boundary tests, type-check and both builds run
# here whenever the changed-file class can affect them.
#
# Bypass when needed (hotfix, reverting, etc.):
#   git push --no-verify
#
# Why boundary tests + type-check + build:h5 + build:mp-weixin:
#   · node:test protects API, migration, auth and account-race contracts
#   · vue-tsc catches ~80% of issues in 5s
#   · build:h5 catches Vite/dynamic-import problems (~25s)
#   · build:mp-weixin catches mp-specific regressions like the
#     URL/Headers polyfill bugs we hit before — Vercel never builds
#     mp so this is the only pre-push gate for the WeChat mini-program
#
# Changed-file classification:
#   · prose-only changes skip every local gate;
#   · API/scripts/migrations/tests/workflow/hook/edge-config changes run the
#     deterministic boundary suite, but do not waste time rebuilding clients;
#   · runtime client/dependency/asset changes run boundaries + type-check +
#     H5 + mp-weixin builds.

set -e

# Color output if terminal supports it
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  RED=$(tput setaf 1); GREEN=$(tput setaf 2); YELLOW=$(tput setaf 3); BOLD=$(tput bold); RESET=$(tput sgr0)
else
  RED=""; GREEN=""; YELLOW=""; BOLD=""; RESET=""
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
APP_DIR="${REPO_ROOT}/app"

if [ ! -d "$APP_DIR" ]; then
  echo "${YELLOW}[pre-push]${RESET} no app/ directory, skipping checks"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────
# Smart skip: are all changed files in the build-irrelevant allow-list?
# ──────────────────────────────────────────────────────────────────
# git pre-push hook receives one line per pushed ref on stdin:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# remote_sha = 40 zeros means "new branch on remote" — diff against
# origin/main as a fallback so first-push branches still get the
# correct file set instead of "everything since the dawn of time".
#
# If stdin is empty (manual hook invocation), we can't determine the
# diff and fall back to running the full check (the safe default).

ZERO_SHA="0000000000000000000000000000000000000000"
DEFAULT_BRANCH="origin/main"

needs_boundary_tests() {
  # Only prose/legal metadata is unable to affect an executable contract.
  case "$1" in
    _ai_notes/*)                  return 1 ;;
    docs/*)                       return 1 ;;
    .gitignore|LICENSE|.gitattributes) return 1 ;;
    *.md|*.txt)                   return 1 ;;
    *)                            return 0 ;;
  esac
}

needs_client_builds() {
  # API/SQL/test/CI changes are executable, but cannot change a compiled H5 or
  # mini-program bundle. Unknown paths deliberately fall through to builds.
  case "$1" in
    _ai_notes/*|docs/*)           return 1 ;;
    .github/*|.githooks/*)        return 1 ;;
    .gitignore|LICENSE|.gitattributes) return 1 ;;
    supabase/migrations/*.sql)    return 1 ;;
    supabase/email-templates/*)   return 1 ;;
    supabase/_ops/*)              return 1 ;;
    api/*)                        return 1 ;;
    scripts/*.mjs|scripts/*.sh)   return 1 ;;
    app/smoke/*)                  return 1 ;;
    tests/*)                      return 1 ;;
    vercel.json)                  return 1 ;;
    *.md|*.txt)                   return 1 ;;
    project.config.json|project.private.config.json) return 1 ;;
    *)                            return 0 ;;
  esac
}

RUN_BOUNDARIES=1
RUN_BUILDS=1

classify_changes() {
  if [ ! -t 0 ]; then
    local stdin_data
    stdin_data="$(cat)"
    if [ -z "$stdin_data" ]; then
      return
    fi
    RUN_BOUNDARIES=0
    RUN_BUILDS=0
    while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
      [ -z "$local_sha" ] && continue
      [ "$local_sha" = "$ZERO_SHA" ] && continue
      local range
      if [ "$remote_sha" = "$ZERO_SHA" ]; then
        if git rev-parse --verify --quiet "$DEFAULT_BRANCH" >/dev/null; then
          range="$DEFAULT_BRANCH..$local_sha"
        else
          RUN_BOUNDARIES=1
          RUN_BUILDS=1
          return
        fi
      else
        range="$remote_sha..$local_sha"
      fi
      local files
      if ! files="$(git diff --name-only "$range" 2>/dev/null)"; then
        RUN_BOUNDARIES=1
        RUN_BUILDS=1
        return
      fi
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        if needs_boundary_tests "$f"; then RUN_BOUNDARIES=1; fi
        if needs_client_builds "$f"; then RUN_BUILDS=1; fi
      done <<< "$files"
    done <<< "$stdin_data"
  fi
}

classify_changes

if [ "$RUN_BOUNDARIES" -eq 0 ] && [ "$RUN_BUILDS" -eq 0 ]; then
  echo "${YELLOW}[pre-push]${RESET} prose-only change — skipping executable gates"
  exit 0
fi

cd "$APP_DIR"

PRE_PUSH_TMP="$(mktemp -d /tmp/illini-pre-push.XXXXXX)"
trap 'rm -rf "$PRE_PUSH_TMP"' EXIT

echo "${BOLD}[pre-push]${RESET} running applicable deterministic gates (--no-verify to bypass)"
echo ""

# ──────────────────────────────────────────────────────────────────
# 1. API / SQL / client boundary tests
# ──────────────────────────────────────────────────────────────────
if [ "$RUN_BOUNDARIES" -eq 1 ]; then
  echo "${BOLD}[boundary]${RESET} node --test api/scripts/client contracts"
  if node --test ../api/*.test.mjs ../scripts/*.test.mjs smoke/*.test.mjs >"$PRE_PUSH_TMP/boundaries.log" 2>&1; then
    echo "  ${GREEN}✓${RESET} boundary tests passed"
  else
    echo "  ${RED}✗${RESET} boundary tests FAILED"
    echo ""
    tail -40 "$PRE_PUSH_TMP/boundaries.log"
    echo ""
    echo "${YELLOW}Push blocked.${RESET} Fix the boundary regression above, or bypass with: ${BOLD}git push --no-verify${RESET}"
    exit 1
  fi
fi

if [ "$RUN_BUILDS" -eq 0 ]; then
  echo "${GREEN}${BOLD}[pre-push] applicable checks passed — pushing.${RESET}"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────
# 2. Type check
# ──────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}[typecheck]${RESET} vue-tsc --noEmit"
if npm run type-check >"$PRE_PUSH_TMP/typecheck.log" 2>&1; then
  echo "  ${GREEN}✓${RESET} type-check passed"
else
  echo "  ${RED}✗${RESET} type-check FAILED"
  echo ""
  tail -30 "$PRE_PUSH_TMP/typecheck.log"
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the type errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

# ──────────────────────────────────────────────────────────────────
# 3. H5 build (matches Vercel's deploy command)
# ──────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}[build-h5]${RESET} npm run build:h5 (this is the one Vercel runs)"
export VITE_SUPABASE_URL="${VITE_SUPABASE_URL:-https://pre-push-stub.supabase.co}"
export VITE_SUPABASE_PUBLISHABLE_KEY="${VITE_SUPABASE_PUBLISHABLE_KEY:-sb_publishable_pre-push-stub-key}"
export VITE_BASE_URL="${VITE_BASE_URL:-https://pre-push-app-stub.invalid}"
# Gate builds go to a throwaway dir, NEVER dist/build/*. They bake the stub
# env above into the bundle, and dist/build/mp-weixin is the artifact
# imported into WeChat DevTools — a push was silently replacing it with a
# stub-URL bundle (request:fail on every API call; mp activation round).
export UNI_OUTPUT_DIR="$PRE_PUSH_TMP/h5"
if npm run build:h5 >"$PRE_PUSH_TMP/build-h5.log" 2>&1; then
  if node ../scripts/verify-build-artifact.mjs "$PRE_PUSH_TMP/h5" local >>"$PRE_PUSH_TMP/build-h5.log" 2>&1; then
    echo "  ${GREEN}✓${RESET} build:h5 + artifact boundary passed"
  else
    echo "  ${RED}✗${RESET} H5 artifact boundary FAILED"
    tail -30 "$PRE_PUSH_TMP/build-h5.log"
    exit 1
  fi
else
  echo "  ${RED}✗${RESET} build:h5 FAILED"
  echo ""
  tail -30 "$PRE_PUSH_TMP/build-h5.log"
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the build errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

# ──────────────────────────────────────────────────────────────────
# 4. mp-weixin build (only gate for WeChat regressions)
# ──────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}[build-mp]${RESET} npm run build:mp-weixin (Vercel never runs this — last line of defense)"
export UNI_OUTPUT_DIR="$PRE_PUSH_TMP/mp-weixin"
if npm run build:mp-weixin >"$PRE_PUSH_TMP/build-mp.log" 2>&1; then
  if node ../scripts/verify-build-artifact.mjs "$PRE_PUSH_TMP/mp-weixin" none >>"$PRE_PUSH_TMP/build-mp.log" 2>&1; then
    echo "  ${GREEN}✓${RESET} build:mp-weixin + artifact boundary passed"
  else
    echo "  ${RED}✗${RESET} mp-weixin artifact boundary FAILED"
    tail -30 "$PRE_PUSH_TMP/build-mp.log"
    exit 1
  fi
else
  echo "  ${RED}✗${RESET} build:mp-weixin FAILED"
  echo ""
  tail -30 "$PRE_PUSH_TMP/build-mp.log"
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the build errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

echo ""
echo "${GREEN}${BOLD}[pre-push] all checks passed — pushing.${RESET}"
exit 0
