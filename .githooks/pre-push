#!/usr/bin/env bash
# Pre-push hook — runs the same checks GitHub Actions runs, locally,
# before the push leaves your machine. Catches type errors and build
# breaks within ~30s instead of 1-2 minutes after CI fails.
#
# Bypass when needed (hotfix, reverting, etc.):
#   git push --no-verify
#
# Why type-check + build:h5 + build:mp-weixin (matches CI exactly):
#   · vue-tsc catches ~80% of issues in 5s
#   · build:h5 catches Vite/dynamic-import problems (~25s)
#   · build:mp-weixin catches mp-specific regressions like the
#     URL/Headers polyfill bugs we hit before — Vercel never builds
#     mp so this is the only pre-push gate for the WeChat mini-program
#
# Smart skip (added 2025-04-25):
#   When the diff between remote and local heads contains ONLY files
#   that can't break the build (docs, migrations, scripts, edge
#   functions, etc.), the type-check + builds are skipped and the
#   push goes through in <1s. The allow-list is conservative — anything
#   touching app/src, vite.config.ts, package.json, or vercel.json
#   triggers the full check.

set -e

# Color output if terminal supports it
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  RED=$(tput setaf 1); GREEN=$(tput setaf 2); YELLOW=$(tput setaf 3); BOLD=$(tput bold); RESET=$(tput sgr0)
else
  RED=""; GREEN=""; YELLOW=""; BOLD=""; RESET=""
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
APP_DIR="${REPO_ROOT}/app"

if [ ! -d "$APP_DIR" ]; then
  echo "${YELLOW}[pre-push]${RESET} no app/ directory, skipping checks"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────
# Smart skip: are all changed files in the build-irrelevant allow-list?
# ──────────────────────────────────────────────────────────────────
# git pre-push hook receives one line per pushed ref on stdin:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# remote_sha = 40 zeros means "new branch on remote" — diff against
# origin/main as a fallback so first-push branches still get the
# correct file set instead of "everything since the dawn of time".
#
# If stdin is empty (manual hook invocation), we can't determine the
# diff and fall back to running the full check (the safe default).

ZERO_SHA="0000000000000000000000000000000000000000"
DEFAULT_BRANCH="origin/main"

is_buildable() {
  # Returns 0 (truthy) if the path needs the full build check.
  # Returns 1 (falsy) for paths that are safe to skip.
  case "$1" in
    _ai_notes/*)                  return 1 ;;
    docs/*)                       return 1 ;;
    .github/*)                    return 1 ;;
    .gitignore|LICENSE|.gitattributes) return 1 ;;
    supabase/migrations/*.sql)    return 1 ;;
    supabase/email-templates/*)   return 1 ;;
    supabase/_ops/*)              return 1 ;;
    api/*)                        return 1 ;;
    scripts/*.mjs|scripts/*.sh)   return 1 ;;
    *.md|*.txt)                   return 1 ;;
    project.config.json|project.private.config.json) return 1 ;;
    *)                            return 0 ;;
  esac
}

determine_skip() {
  if [ ! -t 0 ]; then
    local stdin_data
    stdin_data="$(cat)"
    if [ -z "$stdin_data" ]; then
      return 1
    fi
    while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
      [ -z "$local_sha" ] && continue
      [ "$local_sha" = "$ZERO_SHA" ] && continue
      local range
      if [ "$remote_sha" = "$ZERO_SHA" ]; then
        if git rev-parse --verify --quiet "$DEFAULT_BRANCH" >/dev/null; then
          range="$DEFAULT_BRANCH..$local_sha"
        else
          return 1
        fi
      else
        range="$remote_sha..$local_sha"
      fi
      local files
      files="$(git diff --name-only "$range" 2>/dev/null)" || return 1
      while IFS= read -r f; do
        [ -z "$f" ] && continue
        if is_buildable "$f"; then
          return 1
        fi
      done <<< "$files"
    done <<< "$stdin_data"
    return 0
  fi
  return 1
}

if determine_skip; then
  echo "${YELLOW}[pre-push]${RESET} only docs/migrations/scripts/api changed — skipping type-check + builds"
  exit 0
fi

cd "$APP_DIR"

echo "${BOLD}[pre-push]${RESET} running pre-push checks (~30s, --no-verify to bypass)"
echo ""

# ──────────────────────────────────────────────────────────────────
# 1. Type check
# ──────────────────────────────────────────────────────────────────
echo "${BOLD}[1/3]${RESET} vue-tsc --noEmit"
if npm run type-check >/tmp/pre-push-typecheck.log 2>&1; then
  echo "  ${GREEN}✓${RESET} type-check passed"
else
  echo "  ${RED}✗${RESET} type-check FAILED"
  echo ""
  cat /tmp/pre-push-typecheck.log | tail -30
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the type errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

# ──────────────────────────────────────────────────────────────────
# 2. H5 build (matches Vercel's deploy command)
# ──────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}[2/3]${RESET} npm run build:h5 (this is the one Vercel runs)"
export VITE_SUPABASE_URL="${VITE_SUPABASE_URL:-https://pre-push-stub.supabase.co}"
export VITE_SUPABASE_ANON_KEY="${VITE_SUPABASE_ANON_KEY:-pre-push-stub-anon-key}"
if npm run build:h5 >/tmp/pre-push-build-h5.log 2>&1; then
  echo "  ${GREEN}✓${RESET} build:h5 passed"
else
  echo "  ${RED}✗${RESET} build:h5 FAILED"
  echo ""
  cat /tmp/pre-push-build-h5.log | tail -30
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the build errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

# ──────────────────────────────────────────────────────────────────
# 3. mp-weixin build (only gate for WeChat regressions)
# ──────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}[3/3]${RESET} npm run build:mp-weixin (Vercel never runs this — last line of defense)"
if npm run build:mp-weixin >/tmp/pre-push-build-mp.log 2>&1; then
  echo "  ${GREEN}✓${RESET} build:mp-weixin passed"
else
  echo "  ${RED}✗${RESET} build:mp-weixin FAILED"
  echo ""
  cat /tmp/pre-push-build-mp.log | tail -30
  echo ""
  echo "${YELLOW}Push blocked.${RESET} Fix the build errors above, or bypass with: ${BOLD}git push --no-verify${RESET}"
  exit 1
fi

echo ""
echo "${GREEN}${BOLD}[pre-push] all checks passed — pushing.${RESET}"
exit 0
